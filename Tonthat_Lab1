#main admin app to manage all records
class CheckMyGrade:
    def __init__(self):
        self.students = LinkedList()
        self.professors = LinkedList()
        self.courses = LinkedList()
        self.logins = LinkedList()

    def create_csv(self, filename, headers):
        if not os.path.exists(filename):
            with open(filename, "w", newline="") as newfile:
                writer = csv.DictWriter(newfile, fieldnames = headers)
                writer.writeheader()
            print("CSV Not Found. CSV created for ", filename, " with the following headers: ", headers)   
        else:
            pass

    def load_students(self):
        #clear students list
        self.students = LinkedList()
        #creates csv for students if .csv for students does not exist
        self.create_csv('student.csv',['email address','first_name', 'last_name', 'course_id', 'grade', 'marks'])
        #loads and reads students .csv line for line while adding to students list
        with open ('student.csv', newline="") as studentscsv:
            reader = csv.DictReader(studentscsv)
            for row in reader:
                student = Student(row['email_address'], row['first_name'], row['last_name'], row['course_id'], row['grade'], row['mark'])
                self.students.add_last(student)
    
    def load_courses(self):
        #clear courses list
        self.courses = LinkedList()
        #creates csv for courses if .csv for courses does not exist
        self.create_csv('course.csv',['course_id', 'course_name', 'credits'])
        #loads and reads courses .csv line for line while adding to courses list
        with open ('course.csv', newline="") as coursescsv:
            reader = csv.DictReader(coursescsv)
            for row in reader:
                course = Course(row['course_id'], row['course_name'], row['credits'])
                self.courses.add_last(course)

    def load_professors(self):
        #clear professors list
        self.professors = LinkedList()
        #creates csv for professors if .csv for professors does not exist
        self.create_csv('professor.csv',['name', 'email_address', 'rank', 'course_id'])
        #loads and reads professors .csv line for line while adding to professors list
        with open ('professor.csv', newline="") as professorscsv:
            reader = csv.DictReader(professorscsv)
            for row in reader:
                professor = Professor(row['email_address'], row['name'], row['rank'], row['course_id'])
                self.professors.add_last(professor)
    
    def load_logins(self):
        #clear logins list
        self.logins = LinkedList()
        #creates csv for logins if .csv for logins does not exist
        self.create_csv('login.csv',['email_address', 'password'])
        #loads and reads login .csv line for line while adding to logins list
        with open ('login.csv', newline="") as loginscsv:
            reader = csv.DictReader(loginscsv)
            for row in reader:
                #LoginUser only initialized in main; no need to initialize class now
                user = LoginUser(row["email_address"], row["password"])
                self.logins.add_last(user)
    
    def save_student(self):
        #open csv and begin writing new rows
        with open ('student.csv', 'w', newline="") as studentscsv:
            writer = csv.DictWriter(studentscsv, fieldnames = ['email_address', 'first_name', 'last_name', 'course_id', 'grade', 'marks'])
            writer.writeheader()

            c1 = self.students.head
            while c1 is not None:
                #while next node is not empty, write student row
                student = c1.data
                writer.writerow({
                    'email_address': student.email_address,
                    'first_name': student.firstname,
                    'last_name': student.lastname,
                    'course_id': student.course_id,
                    'grade': student.grades,
                    'marks': student.marks
                })
                c1 = c1.next
    
    def save_course(self):
        with open ('course.csv', 'w', newline="") as coursescsv:
            writer = csv.DictWriter(coursescsv, fieldnames = ['course_id', 'course_name', 'credits'])
            writer.writeheader()
            
            c1 = self.courses.head
            while c1 is not None:
                #while next node is not empty, write course row
                course = c1.data
                writer.writerow({
                    'course_id': course.course_id,
                    'course_name': course.course_name,
                    'credits': course.credits,
                })
                c1 = c1.next

    def save_professor(self):
        with open ('professor.csv', 'w', newline = "") as professorscsv:
            writer = csv.DictWriter(professorscsv, fieldnames = ['email_address', 'name', 'rank', 'course_id'])
            writer.writeheader()
            
            c1 = self.professors.head
            while c1 is not None:
                #while next node is not empty, write professor row
                professor = c1.data
                writer.writerow({
                    'email_address': professor.email_address,
                    'name': professor.name,
                    'rank': professor.rank,
                    'course_id': professor.course_id
                })
                c1 = c1.next

    def existing_student(self, email_address):
        StudentEmail = email_address.strip().lower()
        c1 = self.students.head

        while c1 is not None: #iterate through LL --> return true if node's email matches passed variable email
            student = c1.data
            if student.email_address == StudentEmail:
                return True
            c1 = c1.next
        return False

    def existing_course(self, course_id):
        course_id = course_id.strip().lower()
        c1 = self.courses.head

        while c1 is not None: #iterate through LL --> return true if node's course_id matches passed variable email
            course = c1.data
            if course.course_id == course_id:
                return True
            c1 = c1.next
        return False
    
    def existing_professor(self, email_address):
        ProfEmail = email_address.strip().lower()
        c1 = self.professors.head

        while c1 is not None: #iterate through LL --> return true if node's email matches passed variable email
            professor = c1.data
            if professor.email_address == ProfEmail:
                return True
            c1 = c1.next
        return False

    def add_new_student(self, email_address, firstname, lastname, course_id, grade, marks):
        if self.existing_student(email_address): #if student email already used, throw error and return to retry
            print ("Student already exists")
            return
        #else, add new Student Class, add student to end of linked list, and update csv
        student = Student(email_address, firstname, lastname, course_id, grade, marks)
        self.students.add_last(student)
        self.save_student()
        print(f"Student ID {email_address} successfully added.")

    def display_all_students(self):
        if not self.students.check_head(): #if head is empty, throw error and return to retry.
            print("Error. No students found.")
            return
        #else, interate through linked list and display all students
        c1 = self.students.head
        while c1 is not None:
            c1.data.display_records()
            c1 = c1.next

    def delete_student(self, email_address): 
        email_address = email_address.strip().lower() #normalize email address for easy searching

        if not self.students.check_head(): #check if students list is empty.
            print("Error. No students found in list")    
            return False
        
        elif self.students.head.data.email_address == email_address: #check if students ll first node matches. If so, delete head node.
            self.students.delete_first_node()
            self.save_student()
            print("Student deleted successfully")
            return True

        previous = self.students.head
        current = self.students.head.next

        while current is not None: #else, iterate through linked list and check for matching student.  If so, delete node and save to .csv file.
            if current.data.email_address == email_address:
                previous.next = current.next
                self.save_student()
                print("Student deleted successfully")
                return True
            previous = current
            current = current.next

        print("Error. Student not found.")
        return False


