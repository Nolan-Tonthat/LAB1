        if way == "lastname":
            students_list.sort(key = lambda x: x.lastname, reverse = descending) #sorts student list by lastname, descending variable used to reverse sort
        elif way == "grade":
            students_list.sort(key = lambda x: x.grades, reverse = descending) #sorts student list by grade, descending variable used to reverse sort
        else:
            print("Error. Please enter a different sort field")
            return []
        
        return students_list
    
    def report_student(self, email_address): #report of specific student
        student = self.search_student_by_email(email_address)
        if student is None:
            print("Error. Student Not Found")
            return
        student.display_records() #once student is found, display their records

    def report_course(self,course_id):
        students = self.search_student_by_course(course_id)
        if len(students) == 0:
            print("No students found for this course")
            return
        
        print("Course Report")
        for student in students: #create list of all students that attend the course
            print(student)

        avg = self.course_averages(course_id) 
        med = self.course_median(course_id)
        print("Average Marks: ", avg) #display average and median marks of course
        print("Median Marks: ", med) 

    def report_professor(self, emaiL_address):
        ProfEmail = emaiL_address.strip().lower()
        current = self.professors.head

        while current is not None:
            professor = current.data
            if professor.email_address == ProfEmail:
                professor.professor_details()
                self.report_course(professor.course_id) #display report of professor along with course + students attending course
