    def course_averages(self, course_id):
        course_id = course_id.strip().upper()
        list_mark = []

        #turn marks from linked list and adds to new list_mark
        current = self.students.head
        while current is not None:
            student = current.data
            if student.course_id == course_id:
                list_mark.append(float(student.marks)) #turn marks to float to avoid ValueError

            current = current.next

        #calculation for average
        if len(list_mark) == 0:
            return None
        return sum(list_mark) / len(list_mark)
    
    def course_median(self, course_id):
        course_id = course_id.strip().upper()
        list_mark = []

        current = self.students.head
        while current is not None:
            student = current.data
            if student.course_id == course_id:
                list_mark.append(float(student.marks))

            current = current.next
        
        #calculation for median. uses imported statistics module
        if len(list_mark) == 0:
            return None
        return statistics.median(list_mark)
    

