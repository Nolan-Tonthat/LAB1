#main admin app to manage all records
class CheckMyGrade:
    def __init__(self):
        self.students = []
        self.professors = []
        self.courses = []
        self.logins = []

    def create_csv(self, filename, headers):
        if not os.path.exists(filename):
            with open(filename, "w", newline="") as newfile:
                writer = csv.DictWriter(newfile, fieldnames = headers)
                writer.writeheader()
            print("CSV Not Found. CSV created for " + filename  + " with the following headers: " + headers)   
        else:
            pass

    def load_students(self):
        #clear students list
        students = []
        #creates csv for students if .csv for students does not exist
        self.create_csv('student',['first_name', 'last_name', 'email address', 'course_id', 'grade', 'marks'])
        #loads and reads students .csv line for line while adding to students list
        with open ('student.csv', newline="") as studentscsv:
            reader = csv.DictReader(studentscsv)
            for row in reader:
                students.append(Student(row['first_name'], row['last_name'], row['email_address'], row['course_id'], row['grade'], row['mark']))
        
        return students
    
    def load_courses(self):
        #clear courses list
        courses = []
        #creates csv for courses if .csv for courses does not exist
        self.create_csv('course',['course_id', 'course_name', 'credits'])
        #loads and reads courses .csv line for line while adding to courses list
        with open ('course.csv', newline="") as coursescsv:
            reader = csv.DictReader(coursescsv)
            for row in reader:
                courses.append(Course(row['course_id'], row['course_name'], row['credits']))
        
        return courses

    def load_professors(self):
        #clear professors list
        professors = []
        #creates csv for professors if .csv for professors does not exist
        self.create_csv('professor',['name', 'email_address', 'rank', 'course_id'])
        #loads and reads professors .csv line for line while adding to professors list
        with open ('professor.csv', newline="") as professorscsv:
            reader = csv.DictReader(professorscsv)
            for row in reader:
                professors.append(Professor(row['name'], row['email_address'], row['rank'], row['course_id']))
        
        return professors
    
    def load_logins(self):
        #clear logins list
        logins = []
        #creates csv for logins if .csv for logins does not exist
        self.create_csv('login',['email_address', 'password'])
        #loads and reads login .csv line for line while adding to logins list
        with open ('login.csv', newline="") as loginscsv:
            reader = csv.DictReader(loginscsv)
            for row in reader:
                #LoginUser only initialized in main; no need to initialize class now
                logins.append(row)
        
        return logins
    
    def save_student(self):
        with open ('students.csv', 'w', newline="") as studentscsv:
            writer = csv.DictReader(studentscsv, fieldnames = ['first_name', 'last_name', 'email_address', 'course_id', 'grade', 'mark'])
            writer.writeheader()
            for student in self.students:
                writer.writerow(student.to_dict())
    
    def save_course(self):
        with open ('course.csv', 'w', newline="") as coursescsv:
            writer = csv.DictReader(coursescsv, fieldnames = ['course_id', 'course_name', 'credits'])
            writer.writeheader()
            for course in self.courses:
                writer.writerow(course.to_dict())

    def save_professor(self):
        with open ('professor.csv', 'w', newline = "") as professorscsv:
            writer = csv.DictReader(professorscsv, fieldnames = ['name', 'email_address', 'rank', 'course_id'])
            writer.writeheader()
            for professor in self.professors:
                writer.writerow(professor.to_dict())

    def save_logins(self):
        with open ('login.csv', 'w', newline = "") as loginscsv:
            writer = csv.DictReader(loginscsv, fieldnames = ['user_id', 'password', 'role'])
            writer.writeheader()
            for login in self.logins:
                writer.writerow(login)

    def existing_student(self, email_address):
        semail_address = email_address.strip().lower()
        for student in self.students:
            if student.email_address == semail_address:
                return True
        return False

    def existing_course(self, course_id):
        course_id = course_id.strip().lower()
        for course in self.courses:
            if course.course_id == course_id:
                return True
        return False
    
    def existing_professor(self, pemail_address):
        pemail_address = pemail_address.strip().lower()
        for professor in self.professors:
            if professor.email_address == pemail_address:
                return True
        return False

    

