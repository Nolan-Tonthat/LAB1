#taken from encyc.py, given as part of Lab1
class TextSecurity:
    """This class with encrypt the test using Caesar cipher"""
    def __init__(self, shift):
        """COnstructor."""
        self.shifter=shift
        self.s=self.shifter%26
  
    def _convert(self, text,s):
        """return encrypted string."""
        result=""
        for i,ch in enumerate(text):     
             if (ch.isupper()):
                  result += chr((ord(ch) + s-65) % 26 + 65)
             else:
                  result += chr((ord(ch) + s-97) % 26 + 97)
        return  result
  
    def encrypt(self, text):
        """return encrypted string."""
        return self._convert(text,self.shifter)
        
    def decrypt(self, text):
        """return encrypted string."""
        return self._convert(text,26-self.s) 

class LoginUser:
    def __init__(self, filename = 'login.csv', shift = 3):
        self.file = filename
        self.security = TextSecurity(shift)
        self.logindb = LinkedList()
        self.create_login_file()

    
    def create_login_file(self):
        if not os.path.exists(self.file):
            with open(self.file, 'w', newline = '') as readFile:
                writer = csv.writer(readFile)
                writer.writerow(['email', 'password', 'role'])

    def load_login(self):
        self.logindb.head = None
        with open(self.file, 'r', newline = "") as readFile:
            reader = csv.reader(readFile)
            for row in reader:
                self.logindb.add_last(row)

    def save_login(self):
        with open(self.file, 'w', newline="") as readFile:
            writer = csv.writer(readFile)
            writer.writerow(['email', 'password','role'])

            current = self.logindb.head
            while current is not None:
                writer.writerow(current.data)
                current = current.next

    def user_exists(self, email):
        current = self.logindb.head
        while current is not None:
            if current.data[0] == email:
                return True
            current = current.next
        return False

    def add_user(self, email, password, role):
        if self.user_exists(email):
            print("Error. User already exists with that email. Please try again.")
            return False
        
        encrypted_password = self.security.encrypt(password)

        with open(self.file, 'a', newline="") as readFile:
            writer = csv.writer(readFile)
            writer.writerow([email, encrypted_password, role])

        print("User ", email, " added successfully.")
        return True

    def login(self, email, password):
        """Check login detail"""
        encrypted_password = self.security.encrypt(password)

        with open(self.file, 'r') as file:
            reader = csv.reader(file)
            for row in reader:
                if row[0] == email and row[1] == encrypted_password:
                    print("Login successful for ", row[0])
                    print("Role: ", row[2])
                    return True
                
        print("Invalid email or password")
        return False

    def change_password(self, email, old_password, new_password):
        current = self.logindb.head
        old_encrypted_pw = self.security.encrypt(old_password)
        new_encrypted_pw = self.security.encrypt(new_password)

        while current is not None:
            if current.data[0] == email:
                if current.data[1] == old_encrypted_pw:
                    current.data[1] = new_encrypted_pw
                    self.save_login()
                    print("Password changed successfully.")
                    return True
                else:
                    print("Old password is incorrect.")
                    return False
            current = current.next

        print("User not found.")
        return False

